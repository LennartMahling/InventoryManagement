### 3. PRODUKT MANUELL BEARBEITEN (PUT)
# Testet: Dein "Nein -> Bearbeiten"-Feature vom Frontend.
# WICHTIG: Ersetze die /1/ am Ende der URL mit der ID, die du bei Schritt 1 zurückbekommen hast!
PUT http://localhost:5258/api/inventory/3
Content-Type: application/json

{
  "productName": "Fritz-Kola Original (Manuell geändert)",
  "companyName": "Fritz-Kulturgüter GmbH",
  "quantity": 10,
  "expirationDate": "2027-03-15T00:00:00Z",
  "price": 1.25
}

